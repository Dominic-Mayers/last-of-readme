+    const lorEntry = LOR_HOOK_COMMANDS[hook] || null;
+    const convEntry = LOR_HOOK_CONVENIENCE_COMMANDS[hook] || null;
+    const rawContent = currentHooks[hook] || '';
+
+    const remainingContent = lorEntry
