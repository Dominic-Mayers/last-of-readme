+async function installFingerprintedHookCommand({ hook, lorEntry, remainingContent }) {
+  if (!remainingContent) {
+    setPackageJsonFields({ [`scripts.${hook}`]: lorEntry.command });
+    console.log(`✔ ${hook}: Last of Readme command installed.`);
+    return;
+  }
+
