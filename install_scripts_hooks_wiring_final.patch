+    .replace(new RegExp(`${escapeRegExp(lorCommand)}\\s*&&\\s*`, 'g'), '')
+    .replace(new RegExp(`^${escapeRegExp(lorCommand)}$`), '')
+    .trim();
+}
+
+function escapeRegExp(str) {
+  return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
+}
