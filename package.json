{
  "name": "@dominic.mayers/last-of-readme",
  "version": "0.1.62",
  "description": "Resolve README to last relevant commit based on npm version",
  "author": "Dominic Mayers",
  "license": "MIT",
  "scripts": {
    "start": "last-of-readme install",
    "preversion": "last-of-readme check-contract && last-of-readme tag-doc successor-of",
    "version": "last-of-readme update-readme-link && node scripts/git-add-readme.cjs",
    "postversion": "git push --follow-tags",
    "tag:last-of": "last-of-readme tag-doc last-of",
    "last-of-readme:contract": "last-of-readme contract",
    "tag:correction-of": "last-of-readme tag-doc correction-of",
    "postinstall": "node scripts/last-of-readme/bin/last-of-readme.cjs install"
  },
  "bin": {
    "last-of-readme": "scripts/last-of-readme/bin/last-of-readme.cjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dominic-Mayers/last-of-readme.git"
  },
  "files": [
    "README.md",
    "scripts",
    "docs"
  ],
  "lastOfReadme": {
    "remoteName": "origin",
    "remote": {
      "kind": "github",
      "repositoryApiUrl": "https://api.github.com/repos/Dominic-Mayers/last-of-readme",
      "repositoryBrowserUrl": "https://github.com/Dominic-Mayers/last-of-readme"
    },
    "packageFilePath": "README.md",
    "repositoryUrlPath": "",
    "nextContract": "until-successor-of"
  }
}
