{
  "name": "@dominic.mayers/last-of-readme",
  "version": "0.1.31",
  "description": "Resolve README to last relevant commit based on npm version",
  "author": "Dominic Mayers",
  "license": "MIT",
  "scripts": {
    "preversion": "node scripts/last-of-readme/tag-doc.cjs next-doc",
    "version": "node scripts/last-of-readme/update-readme-link.cjs && node scripts/last-of-readme/git-add-readme.cjs",
    "postversion": "git push --follow-tags",
    "tag:last-doc": "node scripts/last-of-readme/tag-doc.cjs last-doc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dominic-Mayers/last-of-readme"
  },
  "files": [
    "README.md",
    "scripts",
    "docs"
  ],
  "lastOfReadme": {
    "remoteName": "origin",
    "remote": {
      "kind": "github",
      "host": "github.com",
      "repository": "Dominic-Mayers/last-of-readme"
    },
    "packageFilePath": "README.md",
    "repositoryUrlPath": ""
  }
}
